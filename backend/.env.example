# Copy to .env and fill in. Never commit .env.

# --- App ---
# Base URL the app is served from (used to build the OAuth redirect URI).
# For local dev over ngrok use the https ngrok URL, e.g. https://abcd-1234.ngrok-free.app
BASE_URL=http://localhost:8000

# Secret for signing session cookies. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Fernet key for encrypting stored OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-generate-a-fernet-key

# SQLAlchemy database URL. SQLite for dev; swap to Postgres for prod.
DATABASE_URL=sqlite:///./filtration.db

# --- Google OAuth (Gmail read-only) ---
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client (Web application).
# Authorized redirect URI must be: {BASE_URL}/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM backend for the ambiguous mid-band ---
# "anthropic" = paid Claude API (needs ANTHROPIC_API_KEY below).
# "ollama"    = free local model (e.g. Gemma) via Ollama; nothing leaves your machine.
LLM_PROVIDER=ollama

# Anthropic (Claude) — only used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Ollama (local, free) — only used when LLM_PROVIDER=ollama.
# Install Ollama, then: `ollama pull gemma3:4b`. Default endpoint shown below.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# --- Detection tuning ---
# Emails with a rule score in [LLM_ESCALATE_LOW, LLM_ESCALATE_HIGH] get sent to the LLM.
LLM_ESCALATE_LOW=30
LLM_ESCALATE_HIGH=70
# Default number of recent messages a scan fetches.
SCAN_DEFAULT_LIMIT=25
# Set to false to disable all LLM calls entirely (rules-only mode).
LLM_ENABLED=true
